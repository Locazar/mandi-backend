		INNER JOIN promotions p2 ON p2.id = op2.offer_id
		LEFT JOIN promotion_categories pc2 ON p2.promotion_category_id = pc2.id
		LEFT JOIN promotions_types pt2 ON p2.promotion_type_id = pt2.id
