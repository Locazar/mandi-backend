# ---------------------------------------------------------------------------
# ecommerce-notifications Cloud Function – environment variables
# ---------------------------------------------------------------------------

# Which Firestore collection this function handles:
#   "order"   – orders/{orderId}
#   "product" – products/{productId}
#   "shop"    – shops/{shopId}
COLLECTION_TYPE=order

# Comma-separated list of Firestore field names to watch.
# Leave empty to use the per-collection defaults.
#   order   defaults: status,orderStatus,paymentStatus
#   product defaults: verificationStatus,blockStatus,stockStatus,stockQuantity
#   shop    defaults: verificationStatus,blockStatus,isActive
MONITORED_FIELDS=

# Who to notify on a change (true/false):
NOTIFY_USER=true
NOTIFY_SELLER=true

# Logging verbosity: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
