# Configuration file template for Enquiry Notification Handler
# Copy to .env and customize for your environment

# GCP Configuration
GCP_PROJECT_ID=
GCP_REGION=us-central1
FIREBASE_PROJECT_ID=your-firebase-project

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR
DEBUG_MODE=false

# Firestore Configuration
FIRESTORE_DATABASE=default
FCM_TOKEN_COLLECTION=fcmTokens
NOTIFICATION_HISTORY_COLLECTION=notificationHistory

# Monitored Fields Configuration
# Comma-separated list of Firestore fields that trigger notifications
MONITORED_FIELDS=status,assignedTo,priority,resolutionDate,closedAt,tags

# Idempotency Configuration
ENABLE_IDEMPOTENCY_CHECK=true
NOTIFICATION_TTL_HOURS=24  # How long to keep notification history

# Notification Configuration
NOTIFICATION_ICON_URL=https://your-domain.com/icon.png
NOTIFICATION_BATCH_SIZE=10  # Max tokens per batch

# Feature Flags
ENABLE_FCM_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# Service Configuration
SERVICE_TIMEOUT_SECONDS=60
FIRESTORE_QUERY_TIMEOUT_SECONDS=10
MAX_RETRIES=3
RETRY_DELAY_MS=100

# Custom Fields (for advanced use cases)
# Add any custom monitored fields specific to your schema
CUSTOM_MONITORED_FIELDS=

# Authentication
# Set these if using non-default service accounts
FIREBASE_SERVICE_ACCOUNT_JSON=  # Leave empty to use Application Default Credentials
SERVICE_ACCOUNT_EMAIL=firebase-admin@your-project.iam.gserviceaccount.com

# Database Connections (if needed)
FIREBASE_DB_URL=
FIRESTORE_EMULATOR_HOST=  # Only for local testing: localhost:8080
GOOGLE_APPLICATION_CREDENTIALS="locazar-f20b6-c125ff67e902.json"
